KAFKA_BOOTSTRAP_SERVERS=kafka:9092
TRIPS_TOPIC=trips.raw
STATUS_TOPIC=ingestion.status
DELTA_BASE_PATH=data/delta
CHECKPOINT_BASE_PATH=data/checkpoints
POSTGRES_URL=jdbc:postgresql://postgres:5432/trips
POSTGRES_USER=trips
POSTGRES_PASSWORD=trips
POSTGRES_DB=trips
PUBLISH_DELAY_SECONDS=0
MAX_OFFSETS_PER_TRIGGER=100
MAX_FILES_PER_TRIGGER=10
