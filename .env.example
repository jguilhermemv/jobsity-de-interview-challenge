KAFKA_BOOTSTRAP_SERVERS=kafka:9092
TRIPS_TOPIC=trips.raw
STATUS_TOPIC=ingestion.status
DELTA_BASE_PATH=data/delta
CHECKPOINT_BASE_PATH=data/checkpoints
POSTGRES_URL=jdbc:postgresql://postgres:5432/trips
POSTGRES_USER=trips
POSTGRES_PASSWORD=trips
POSTGRES_DB=trips

# Ingestion pacing — delay between Kafka events published by the API.
# Lower = faster ingestion; higher = slower trickle (more visible in demo).
# 0.1 s → 100 rows published in ~10 s (recommended for demo)
# 0.5 s → 100 rows published in ~50 s (too slow to observe live)
PUBLISH_DELAY_SECONDS=0.1

# Spark Job 1 — max Kafka offsets consumed per micro-batch trigger.
# Controls how many events Job1 reads from Kafka each 5-second trigger.
# 25 → ~5 visible jumps in the PostgreSQL counter for a 100-row dataset.
MAX_OFFSETS_PER_TRIGGER=25

# Spark Job 2 — max Silver Delta files read per micro-batch trigger.
# Higher values make Job2 catch up faster but increase memory pressure.
MAX_FILES_PER_TRIGGER=10

# Job 2 resilience (PostgreSQL writes) — retry transient failures
POSTGRES_WRITE_MAX_RETRIES=3
POSTGRES_WRITE_INITIAL_BACKOFF=2.0
POSTGRES_CONNECT_TIMEOUT=15
